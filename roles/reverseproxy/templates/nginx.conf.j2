events {}

http {
    server {
        listen 80;
        server_name {{ ansible_host }};

        return 301 https://$server_name$request_uri;
    }

    server {
        listen 443 ssl;
        server_name pihole.{{ domain }};

        ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

        location / {
            proxy_pass http://{{ hostvars['pihole'].ansible_host }};
            proxy_set_header Host $host;
        }
    }

    server {
        listen 80;
        server_name nextcloud.{{ domain }};

        return 301 https://$server_name$request_uri;
    }

    server {
        listen 443 ssl;
        server_name {{ ansible_host }};

        ssl_certificate /etc/nginx/certs/danielellert.com.crt;
        ssl_certificate_key /etc/nginx/certs/danielellert.com.key;

        location /nextcloud/ {
            proxy_pass http://{{ hostvars['nextcloud'].ansible_host }}/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /nextcloud;
        }
    }

    server {
        listen 443 ssl;
        server_name nextcloud.{{ domain }};

        ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

        location /nextcloud/ {
            proxy_pass http://{{ hostvars['nextcloud'].ansible_host }}/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /nextcloud;
        }
    }

    server {
        listen 443 ssl;
        server_name gitea.{{ domain }};

        ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

        location / {
            proxy_pass http://{{ hostvars['gitea'].ansible_host }}:3000;
        }
    }

    server {
        listen 443 ssl;
        server_name navidrome.{{ domain }};

        ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

        location / {
            proxy_pass http://{{ hostvars['navidrome'].ansible_host }};
        }
    }

    server {
        listen 443 ssl;
        server_name yourspotify.{{ domain }};

        ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

        location / {
            proxy_pass http://{{ hostvars['yourspotify'].ansible_host }}:3000;
        }
    }

    server {
        listen 443 ssl;
        server_name yourspotifyapi.{{ domain }};

        ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

        location / {
            proxy_pass http://{{ hostvars['yourspotify'].ansible_host }}:8080;
        }
    }

    server {
        listen 443 ssl;
        server_name wireguardui.{{ domain }};

        ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

        location / {
            proxy_pass http://{{ hostvars['wireguard'].ansible_host }}:51821;
        }
    }

    server {
        listen 443 ssl;
        server_name immich.{{ domain }};

        ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

        location / {
            proxy_pass http://{{ hostvars['immich'].ansible_host }}:3001;
        }
    }
}
