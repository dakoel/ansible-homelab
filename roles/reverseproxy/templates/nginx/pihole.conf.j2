server {
    listen 443 ssl;
    server_name pihole.{{ domain }};

    ssl_certificate /etc/nginx/certs/{{ domain }}.crt;
    ssl_certificate_key /etc/nginx/certs/{{ domain }}.key;

    location / {
        proxy_pass http://{{ hostvars['pihole'].ansible_host }};
        proxy_set_header Host $host;
    }
}
