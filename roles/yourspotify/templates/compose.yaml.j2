---
version: "3.8"

services:
  server:
    image: yooooomi/your_spotify_server
    restart: always
    ports:
      - "8080:8080"
    links:
      - mongo
    depends_on:
      - mongo
    environment:
      API_ENDPOINT: http://{{ inventory_hostname }}.{{ dns_root_domain }}:8080
      CLIENT_ENDPOINT: http://{{ inventory_hostname }}.{{ dns_root_domain }}:80
      SPOTIFY_PUBLIC: {{ spotify_public }}
      SPOTIFY_SECRET: {{ spotify_secret }}
  mongo:
    container_name: mongo
    image: mongo:6
    volumes:
      - ./db:/data/db

  web:
    image: yooooomi/your_spotify_client
    restart: always
    ports:
      - "80:3000"
    environment:
      API_ENDPOINT: http://{{ inventory_hostname }}.{{ dns_root_domain }}:8080
