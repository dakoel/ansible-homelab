---
version: "3"

services:
  server:
    image: yooooomi/your_spotify_server
    restart: always
    ports:
      - "8080:8080"
    links:
      - mongo
    depends_on:
      - mongo
    environment:
      API_ENDPOINT: http://{{ hostvars['your_spotify'].ansible_host }}:8080
      CLIENT_ENDPOINT: http://{{ hostvars['your_spotify'].ansible_host }}:80
      SPOTIFY_PUBLIC: {{ hostvars['your_spotify'].spotify_public }}
      SPOTIFY_SECRET: {{ hostvars['your_spotify'].spotify_secret }}
  mongo:
    container_name: mongo
    image: mongo:6
    volumes:
      - ./db:/data/db

  web:
    image: yooooomi/your_spotify_client
    restart: always
    ports:
      - "80:3000"
    environment:
      API_ENDPOINT: http://{{ hostvars['your_spotify'].ansible_host }}:8080
