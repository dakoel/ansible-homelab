---
version: "3.8"

services:
  wg-easy:
    image: weejewel/wg-easy
    container_name: wg-easy
    restart: always
    environment:
      - WG_HOST={{ wireguard_host }}
      - PASSWORD={{ wireguard_web_password }}
      - WG_DEFAULT_DNS={{ hostvars['pihole'].ansible_host }}
    volumes:
      - ./data:/etc/wireguard
    ports:
      - "51820:51820/udp"
      - "51821:51821/tcp"
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1
