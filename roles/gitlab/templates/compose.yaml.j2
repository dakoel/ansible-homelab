---
services:
  gitlab:
    image: gitlab/gitlab-ce:{{ gitlab_tag }}
    restart: always
    hostname: "{{ inventory_hostname }}.{{ domain }}"
    environment:
      GITLAB_OMNIBUS_CONFIG: |
        external_url "http://{{ inventory_hostname }}.{{ domain }}"
        gitlab_rails["initial_root_password"] = "{{ gitlab_root_password }}"
    volumes:
      - ./config:/etc/gitlab
      - ./logs:/var/log/gitlab
      - ./data:/var/opt/gitlab
    ports:
      - "22:22"
      - "80:80"
